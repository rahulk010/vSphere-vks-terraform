# Local .terraform directory (contains binaries and cached modules)
**/.terraform/*

# Terraform state files (contains sensitive plain-text data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (as they often contain sensitive deployment variables)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
